{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a financial transaction (income, expense, or investment).",
      "type": "object",
      "properties": {
        "description": {
          "type": "string",
          "description": "Short description of the transaction"
        },
        "amount": {
          "type": "number",
          "description": "Value of the transaction"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Date of the transaction"
        },
        "dueDate": {
          "type": "string",
          "format": "date",
          "description": "Due date of the transaction"
        },
        "type": {
          "type": "string",
          "enum": [
            "receita",
            "despesa",
            "investimento"
          ],
          "description": "Type of the transaction"
        },
        "userId": {
          "type": "string",
          "description": "ID of the user who owns this transaction"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": [
        "description",
        "amount",
        "date",
        "dueDate",
        "type",
        "userId"
      ]
    }
  },
  "firestore": {
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User financial transactions"
    }
  }
}
