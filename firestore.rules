rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Transaction Entity Validation ---
    function isValidTransaction(data) {
      return data.keys().hasAll(['description', 'amount', 'date', 'dueDate', 'type', 'userId', 'createdAt'])
        && data.keys().size() == 7
        && data.description is string && data.description.size() <= 200
        && data.amount is number
        && data.date is string && data.date.size() <= 64
        && data.dueDate is string && data.dueDate.size() <= 64
        && data.type in ['receita', 'despesa', 'investimento']
        && data.userId == request.auth.uid
        && (data.createdAt == request.time || data.createdAt is string); // Handling both Timestamp and ISO string if needed, but logic says use request.time
    }

    match /transactions/{transactionId} {
      // Secure list: enforced by resource.data check
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isOwner(existing().userId);

      allow create: if isSignedIn() 
        && isValidId(transactionId)
        && isValidTransaction(incoming())
        && incoming().createdAt == request.time;

      allow update: if isOwner(existing().userId)
        && isValidTransaction(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['description', 'amount', 'date', 'dueDate', 'type']);

      allow delete: if isOwner(existing().userId);
    }
  }
}
